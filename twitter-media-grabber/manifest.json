{
  "manifest_version": 3,
  "name": "Twitter/X Media Grabber",
  "version": "1.0.0",
  "description": "Grab subtitles (captions) and audio from videos playing on twitter.com / x.com.",
  "permissions": ["activeTab", "scripting", "downloads", "offscreen"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.twimg.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Twitter/X Media Grabber",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["src/lib/vtt.js", "src/lib/m3u8.js", "src/lib/transcript.js", "src/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
