{
  "manifest_version": 3,
  "name": "Video Media Grabber",
  "version": "1.2.0",
  "description": "Grab audio and subtitles from any website's video, and transcribe speech to text locally (Whisper) — including real-time live transcription that generates subtitles for videos that have none.",
  "permissions": ["activeTab", "scripting", "downloads", "offscreen"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_title": "Video Media Grabber",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/lib/vtt.js", "src/lib/m3u8.js", "src/lib/transcript.js", "src/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
